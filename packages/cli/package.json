{
  "name": "@hareru/cli",
  "version": "0.2.0",
  "description": "CLI for Hareru UI design system — add components, manage CSS imports",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hareru-ai/ui",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/hareru-ai/ui",
  "keywords": [
    "cli",
    "design-system",
    "hareru",
    "css"
  ],
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hareru": "./bin/hareru.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@hareru/registry": "workspace:*",
    "commander": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
