{
  "name": "@hareru/ui",
  "version": "0.1.0",
  "description": "Semantic CSS component library for Hareru UI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hareru-ai/ui",
    "directory": "packages/ui"
  },
  "homepage": "https://github.com/hareru-ai/ui",
  "keywords": ["react", "components", "design-system", "hareru", "semantic-css"],
  "sideEffects": ["*.css"],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css",
    "./styles.layer.css": "./dist/styles.layer.css",
    "./styles/baseline.css": "./dist/styles/baseline.css",
    "./styles/components.css": "./dist/styles/components.css",
    "./styles/components.layer.css": "./dist/styles/components.layer.css",
    "./styles/scope.css": "./dist/styles/scope.css",
    "./styles/animations.css": "./dist/styles/animations.css",
    "./styles/components/*.css": "./dist/styles/components/*.css",
    "./component-registry.json": "./dist/component-registry.json",
    "./component-registry.schema.json": "./dist/component-registry.schema.json",
    "./consumer-rules.json": "./dist/consumer-rules.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist", "LICENSE"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@hareru/tokens": "workspace:*",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "react-grid-layout": "^2.2.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^20.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
