{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hareru.ai/schemas/component-registry.json",
  "title": "Hareru UI Component Registry",
  "type": "object",
  "required": ["$schema", "name", "version", "componentCount", "components"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "componentCount": {
      "type": "integer",
      "minimum": 0
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ComponentEntry"
      }
    },
    "taskBundles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TaskBundle"
      }
    }
  },
  "$defs": {
    "ComponentEntry": {
      "type": "object",
      "required": [
        "name",
        "displayName",
        "group",
        "componentSource",
        "cssArtifact",
        "requiredCssArtifacts",
        "tokenCategories",
        "description"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "group": {
          "type": "string",
          "enum": [
            "core",
            "form",
            "layout",
            "overlay",
            "navigation",
            "feedback",
            "data-display",
            "agent",
            "di-domain"
          ]
        },
        "componentSource": {
          "type": "string"
        },
        "cssArtifact": {
          "type": "string"
        },
        "requiredCssArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokenCategories": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "color",
              "spacing",
              "radius",
              "font",
              "typography",
              "shadow",
              "duration",
              "easing",
              "zIndex"
            ]
          }
        },
        "description": {
          "type": "string"
        },
        "aiHint": {
          "type": "string"
        },
        "peerComponents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "subcomponents": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "variants": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/VariantEntry"
          }
        },
        "props": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/PropsEntry"
          }
        },
        "states": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/StateDef"
          }
        },
        "a11y": {
          "$ref": "#/$defs/A11yDef"
        },
        "examples": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/ExampleDef"
          }
        },
        "slots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/SlotDef"
          }
        }
      }
    },
    "VariantEntry": {
      "type": "object",
      "required": ["name", "variants", "defaultVariants"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "variants": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "defaultVariants": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      }
    },
    "PropsEntry": {
      "type": "object",
      "required": ["name", "extends"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "extends": {
          "type": ["string", "null"]
        },
        "customProps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/CustomProp"
          }
        }
      }
    },
    "CustomProp": {
      "type": "object",
      "required": ["name", "type", "required"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "StateDef": {
      "type": "object",
      "required": ["name", "type"],
      "oneOf": [
        {
          "properties": {
            "name": { "type": "string" },
            "type": { "const": "boolean" },
            "cssReflection": { "type": "string", "enum": ["modifier", "data-attribute"] }
          },
          "required": ["name", "type"],
          "additionalProperties": false
        },
        {
          "properties": {
            "name": { "type": "string" },
            "type": { "const": "enum" },
            "values": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "defaultValue": { "type": "string" },
            "cssReflection": { "type": "string", "enum": ["modifier", "data-attribute"] }
          },
          "required": ["name", "type", "values"],
          "additionalProperties": false
        }
      ]
    },
    "A11yDef": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "roles": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ariaAttributes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "semanticElements": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "keyboardInteractions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "liveRegion": {
          "type": "boolean"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "ExampleDef": {
      "type": "object",
      "required": ["title", "code"],
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "code": {
          "type": "string"
        }
      }
    },
    "SlotDef": {
      "type": "object",
      "required": ["name", "role", "parent", "expected", "multiple"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": [
            "trigger",
            "content",
            "container",
            "item",
            "label",
            "description",
            "action",
            "separator",
            "indicator",
            "viewport",
            "close",
            "icon",
            "input",
            "submenu",
            "anchor",
            "control"
          ]
        },
        "parent": {
          "type": "string"
        },
        "expected": {
          "type": "boolean"
        },
        "multiple": {
          "type": "boolean"
        }
      }
    },
    "TaskBundle": {
      "type": "object",
      "required": ["name", "description", "components", "cssArtifacts", "tokenCategories"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "components": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "cssArtifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tokenCategories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
