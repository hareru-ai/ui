{
  "$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
  "files": {
    "ignore": [
      "**/dist/**",
      "**/.turbo/**",
      "**/node_modules/**",
      "**/e2e/**",
      "**/test-results/**",
      "**/playwright-report/**",
      "**/.next/**",
      "**/.source/**",
      "**/*.module.css",
      "**/next-env.d.ts"
    ]
  },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "javascript": {
    "formatter": { "quoteStyle": "single" }
  }
}
